{
  "document_id": "ES-PCM-2024-001",
  "title": "PCM Power Mode State Machine Specification",
  "revision": "C",
  "subsystem": "Powertrain Control Module",
  "asil": "ASIL-B",
  "effective_date": "2024-03-15",
  "states": [
    {"state_id": "OFF", "code": "0x00", "name": "OFF", "description": "All vehicle systems disabled", "active_systems": []},
    {"state_id": "ACC", "code": "0x01", "name": "ACCESSORY", "description": "Infotainment and accessory power", "active_systems": ["Radio", "USB", "12V outlets"]},
    {"state_id": "RUN", "code": "0x02", "name": "RUN", "description": "All ECUs powered, engine off", "active_systems": ["All ECUs", "Fuel pump prime", "Gauges"]},
    {"state_id": "CRANK", "code": "0x03", "name": "CRANK", "description": "Starter motor engaged", "active_systems": ["Starter relay", "Ignition coils"]},
    {"state_id": "RUN_ENGINE", "code": "0x04", "name": "RUN+ENGINE", "description": "Normal driving operation", "active_systems": ["Full powertrain", "Transmission"]},
    {"state_id": "EMERGENCY", "code": "0x05", "name": "EMERGENCY STOP", "description": "Fault-triggered shutdown", "active_systems": ["Hazard lights", "Fuel pump shutoff"]}
  ],
  "transitions": [
    {"from_state": "OFF", "to_state": "ACC", "condition": "IGN_SW = ACC", "guard": "BATT_V > 9.0V", "category": "forward"},
    {"from_state": "ACC", "to_state": "RUN", "condition": "IGN_SW = RUN", "guard": "BATT_V > 10.5V", "category": "forward"},
    {"from_state": "RUN", "to_state": "CRANK", "condition": "START_REQ = 1", "guard": "TRANS_RANGE = P/N, BRAKE = ON", "category": "forward"},
    {"from_state": "CRANK", "to_state": "RUN_ENGINE", "condition": "ENGINE_RPM > 400", "guard": "", "timeout_ms": 10000, "category": "forward"},
    {"from_state": "RUN", "to_state": "ACC", "condition": "IGN_SW = ACC", "guard": "", "category": "reverse"},
    {"from_state": "ACC", "to_state": "OFF", "condition": "IGN_SW = OFF", "guard": "", "category": "reverse"},
    {"from_state": "RUN", "to_state": "OFF", "condition": "IGN_SW = OFF", "guard": "Direct shutdown", "category": "reverse"},
    {"from_state": "CRANK", "to_state": "RUN", "condition": "START_REQ = 0", "guard": "Crank abort", "category": "reverse"},
    {"from_state": "RUN_ENGINE", "to_state": "RUN", "condition": "ENGINE_STALL", "guard": "RPM < 200 for 2s", "category": "reverse"},
    {"from_state": "RUN_ENGINE", "to_state": "EMERGENCY", "condition": "FAULT_CRITICAL = 1", "guard": "", "category": "emergency"},
    {"from_state": "RUN_ENGINE", "to_state": "EMERGENCY", "condition": "OIL_PRESS < 5 psi", "guard": "", "category": "emergency"},
    {"from_state": "RUN_ENGINE", "to_state": "EMERGENCY", "condition": "COOLANT_TEMP > 120C", "guard": "", "category": "emergency"},
    {"from_state": "CRANK", "to_state": "EMERGENCY", "condition": "CRANK_TIMEOUT > 10s", "guard": "", "category": "emergency"},
    {"from_state": "EMERGENCY", "to_state": "OFF", "condition": "FAULT_CLEARED", "guard": "Manual reset required", "category": "emergency"}
  ],
  "input_signals": [
    {"name": "IgnitionSwitch", "message_id": "0x510", "bit_position": 0, "length": 3, "scale": 1, "unit": "enum"},
    {"name": "BatteryVoltage", "message_id": "0x512", "bit_position": 0, "length": 16, "scale": 0.01, "unit": "V"},
    {"name": "EngineRPM", "message_id": "0x120", "bit_position": 0, "length": 16, "scale": 0.25, "unit": "rpm"},
    {"name": "StartRequest", "message_id": "0x511", "bit_position": 0, "length": 1, "scale": 1, "unit": "bool"},
    {"name": "TransRange", "message_id": "0x210", "bit_position": 4, "length": 4, "scale": 1, "unit": "enum"},
    {"name": "BrakePedal", "message_id": "0x310", "bit_position": 0, "length": 1, "scale": 1, "unit": "bool"},
    {"name": "OilPressure", "message_id": "0x122", "bit_position": 0, "length": 8, "scale": 0.5, "unit": "psi"},
    {"name": "CoolantTemp", "message_id": "0x123", "bit_position": 0, "length": 8, "scale": 1, "unit": "C"},
    {"name": "FaultCritical", "message_id": "0x7F0", "bit_position": 0, "length": 1, "scale": 1, "unit": "bool"}
  ],
  "output_signals": [
    {"name": "PowerModeState", "message_id": "0x130", "bit_position": 0, "length": 8, "scale": 1, "unit": "enum"},
    {"name": "StarterRelay", "message_id": "0x131", "bit_position": 0, "length": 1, "scale": 1, "unit": "bool"},
    {"name": "FuelPumpRelay", "message_id": "0x131", "bit_position": 1, "length": 1, "scale": 1, "unit": "bool"},
    {"name": "IgnitionCoilEn", "message_id": "0x131", "bit_position": 2, "length": 1, "scale": 1, "unit": "bool"}
  ],
  "dtcs": [
    {"code": "P0335", "description": "Crankshaft Position Sensor", "enable_condition": "RUN+ENGINE, RPM = 0 for 5s", "mil": true},
    {"code": "P0562", "description": "System Voltage Low", "enable_condition": "Any mode, BATT_V < 9.0V for 30s", "mil": true},
    {"code": "P0563", "description": "System Voltage High", "enable_condition": "Any mode, BATT_V > 16.0V for 10s", "mil": true},
    {"code": "P0602", "description": "PCM Calibration Error", "enable_condition": "Power-on self-test", "mil": true},
    {"code": "U0100", "description": "Lost Communication with ECM", "enable_condition": "RUN or RUN+ENGINE, no msg for 1s", "mil": true}
  ],
  "diagrams": ["diagrams/pcm_state_machine.png"],
  "tables": 7,
  "figures": 1
}
